{
  "name": "imas-portal-cli",
  "version": "0.1.0",
  "description": "Query THE iDOLM@STER official portal news & schedule from the terminal and from LLM agents.",
  "type": "module",
  "bin": {
    "imas": "dist/imas.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node dist/imas.js news --limit 1 --json",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "idolmaster",
    "imas",
    "cli",
    "mcp",
    "news",
    "schedule",
    "agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fotoner/imas-portal-cli.git"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "env-paths": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "undici": "^6.19.8",
    "vitest": "^2.0.5"
  }
}
